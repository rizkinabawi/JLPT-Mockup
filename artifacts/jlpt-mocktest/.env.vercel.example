# ==========================================
# JLPT Mocktest — Environment Variables
# ==========================================
# Copy variabel-variabel ini ke Vercel Project Settings → Environment Variables

# -------------------------------------------
# WAJIB: Kunci enkripsi soal ujian
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------
VITE_EXAM_KEY=isi_64_karakter_hex_di_sini

# -------------------------------------------
# Google AdSense (opsional — sudah hardcoded ca-pub-9450003707454763)
# Isi jika ingin override publisher ID
# -------------------------------------------
# VITE_ADSENSE_CLIENT=ca-pub-9450003707454763

# Slot ID untuk banner atas halaman utama (Horizontal/Leaderboard)
VITE_ADSENSE_SLOT_BANNER_TOP=XXXXXXXXXX

# Slot ID untuk banner tengah halaman utama
VITE_ADSENSE_SLOT_BANNER_MID=XXXXXXXXXX

# Slot ID untuk banner bawah halaman utama
VITE_ADSENSE_SLOT_BANNER_BOTTOM=XXXXXXXXXX

# Slot ID untuk iklan di modal unlock paket (Display 300x250 atau Responsif)
VITE_ADSENSE_SLOT_GATE=XXXXXXXXXX
