# ==========================================
# JLPT Mocktest — Environment Variables
# ==========================================
# Copy variabel-variabel ini ke Vercel Project Settings → Environment Variables

# -------------------------------------------
# WAJIB: Kunci enkripsi soal ujian
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -------------------------------------------
VITE_EXAM_KEY=isi_64_karakter_hex_di_sini

# -------------------------------------------
# Google AdSense — Iklan Banner & Interstitial
# Daftarkan di: https://adsense.google.com
# Format Publisher ID: ca-pub-XXXXXXXXXXXXXXXX
# -------------------------------------------
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Slot ID banner atas halaman utama (Leaderboard 728x90 atau Responsif Horizontal)
VITE_ADSENSE_SLOT_BANNER_TOP=XXXXXXXXXX

# Slot ID banner tengah halaman utama
VITE_ADSENSE_SLOT_BANNER_MID=XXXXXXXXXX

# Slot ID banner bawah halaman utama
VITE_ADSENSE_SLOT_BANNER_BOTTOM=XXXXXXXXXX

# Slot ID iklan di modal unlock paket (Display Persegi 300x250 atau Responsif)
VITE_ADSENSE_SLOT_GATE=XXXXXXXXXX
